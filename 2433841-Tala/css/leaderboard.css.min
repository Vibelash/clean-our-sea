:root{--white:#ffffff;--bg-top:#032340;--bg-mid:#0b4f7a;--bg-bottom:#1e88b5;--surface:rgba(255,255,255,0.96);--surface-dim:rgba(255,255,255,0.08);--border:rgba(255,255,255,0.18);--text-dark:#0f2230;--text-mid:#546876;--text-light:#ffffff;--text-hint:#9fb6c4;--accent:#29b6f6;--accent-dark:#0288d1;--accent-soft:#b3e5fc;--success:#2dd4bf;--danger:#ef4444;--warn:#f59e0b;--shadow-sm:0 2px 6px rgba(0,0,0,0.08);--shadow-md:0 10px 30px rgba(0,20,40,0.25);--shadow-lg:0 20px 60px rgba(0,20,40,0.35);--radius-sm:8px;--radius-md:14px;--radius-lg:22px}.leaderboard-container{max-width:1100px;margin:0 auto;padding:40px 20px}.page-title{font-size:2.8rem;font-weight:700;color:var(--text-light);text-align:center;margin-bottom:12px;letter-spacing:-0.5px}.page-subtitle{font-size:1.1rem;color:var(--text-hint);text-align:center;margin-bottom:40px;font-weight:400}#timer{position:absolute;top:20px;right:20px;background:var(--surface);border:1px solid var(--border);padding:12px 20px;border-radius:var(--radius-md);font-size:0.95rem;font-weight:600;color:var(--accent);box-shadow:var(--shadow-sm)}#weekly-quota-section{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-lg);padding:32px;margin-bottom:32px;box-shadow:var(--shadow-md)}.quota-container{background:transparent}.quota-display{display:flex;justify-content:space-between;align-items:center;margin-bottom:24px;gap:20px;flex-wrap:wrap}.quota-display>div{display:flex;flex-direction:column;gap:6px}.quota-display .label{font-size:0.9rem;color:var(--text-mid);font-weight:500;text-transform:uppercase;letter-spacing:0.5px}.quota-display .value{font-size:2rem;font-weight:700;color:var(--text-dark)}.quota-display .value.accent{color:var(--accent)}.progress-bar-container{width:100%;height:12px;background:var(--surface-dim);border-radius:var(--radius-sm);overflow:hidden;margin-bottom:24px;border:1px solid var(--border)}#progress-bar{height:100%;background:linear-gradient(90deg,var(--accent) 0%,var(--success) 100%);border-radius:var(--radius-sm);transition:width 0.6s cubic-bezier(0.4,0.0,0.2,1);position:relative}#progress-bar::after{content:'';position:absolute;top:0;left:0;right:0;bottom:0;background:linear-gradient(90deg,transparent,rgba(255,255,255,0.3),transparent);animation:shimmer 2s infinite}@keyframes shimmer{0%{transform:translateX(-100%)}100%{transform:translateX(100%)}}.quota-input{display:flex;gap:12px;flex-wrap:wrap;align-items:flex-end}.quota-input input{flex:1;min-width:200px;padding:12px 16px;border:1px solid var(--border);border-radius:var(--radius-md);font-size:1rem;color:var(--text-dark);background:rgba(255,255,255,0.5);transition:all 0.2s ease}.quota-input input:focus{outline:none;border-color:var(--accent);background:var(--white);box-shadow:0 0 0 3px rgba(41,182,246,0.1)}.quota-input input::placeholder{color:var(--text-hint)}.quota-input button{padding:12px 28px;background:var(--accent);color:var(--text-light);border:none;border-radius:var(--radius-md);font-size:1rem;font-weight:600;cursor:pointer;transition:all 0.2s ease;box-shadow:var(--shadow-sm)}.quota-input button:hover{background:var(--accent-dark);transform:translateY(-2px);box-shadow:var(--shadow-md)}.quota-input button:active{transform:translateY(0)}.tab-buttons{display:flex;justify-content:center;gap:12px;margin-bottom:32px;flex-wrap:wrap}.tab-buttons button{padding:10px 20px;background:var(--surface-dim);color:var(--text-mid);border:1px solid var(--border);border-radius:var(--radius-md);font-size:0.95rem;font-weight:600;cursor:pointer;transition:all 0.2s ease}.tab-buttons button:hover{border-color:var(--accent);color:var(--accent)}.tab-buttons button.active{background:var(--accent);color:var(--text-light);border-color:var(--accent);box-shadow:0 0 0 3px rgba(41,182,246,0.2)}.filter{margin-bottom:24px}.filter select{padding:10px 16px;background:var(--surface);color:var(--text-dark);border:1px solid var(--border);border-radius:var(--radius-md);font-size:0.95rem;cursor:pointer;transition:all 0.2s ease}.filter select:focus{outline:none;border-color:var(--accent);box-shadow:0 0 0 3px rgba(41,182,246,0.1)}#top-three{display:flex;justify-content:center;align-items:flex-end;gap:16px;margin-bottom:40px;flex-wrap:wrap;min-height:320px}.top-contributor{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-lg);padding:24px 20px;text-align:center;transition:all 0.3s ease;display:flex;flex-direction:column;justify-content:flex-end;position:relative;flex:0 1 200px;cursor:pointer}.top-contributor:hover{transform:translateY(-4px);box-shadow:var(--shadow-lg)}.top-contributor .medal{font-size:3.5rem;margin-bottom:12px;display:block;animation:float 3s ease-in-out infinite}@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-8px)}}.top-contributor .name{font-size:1.2rem;font-weight:700;color:var(--text-dark);margin-bottom:8px}.top-contributor .points{font-size:1.8rem;font-weight:700;color:var(--accent);margin-bottom:8px}.top-contributor .label{font-size:0.85rem;color:var(--text-hint);font-weight:500;text-transform:uppercase;letter-spacing:0.5px}.top-contributor:nth-child(1){order:2;min-height:320px;background:linear-gradient(135deg,var(--surface) 0%,rgba(245,158,11,0.08) 100%);border:2px solid rgba(245,158,11,0.4);box-shadow:0 0 30px rgba(245,158,11,0.25),var(--shadow-lg)}.top-contributor:nth-child(1):hover{box-shadow:0 0 40px rgba(245,158,11,0.35),var(--shadow-lg)}.top-contributor:nth-child(2){order:1;min-height:280px;background:linear-gradient(135deg,var(--surface) 0%,rgba(209,213,219,0.08) 100%);border:1.5px solid rgba(209,213,219,0.3)}.top-contributor:nth-child(3){order:3;min-height:240px;background:linear-gradient(135deg,var(--surface) 0%,rgba(180,83,9,0.08) 100%);border:1.5px solid rgba(180,83,9,0.3)}#leaderboard{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-lg);overflow:hidden;box-shadow:var(--shadow-md)}table{width:100%;border-collapse:collapse}thead{background:linear-gradient(90deg,var(--bg-mid) 0%,var(--bg-bottom) 100%)}thead th{padding:16px 20px;text-align:left;font-size:0.9rem;font-weight:700;color:var(--text-light);text-transform:uppercase;letter-spacing:0.5px;border-bottom:2px solid var(--border)}tbody tr{border-bottom:1px solid var(--border);transition:all 0.2s ease}tbody tr:nth-child(even){background:var(--surface-dim)}tbody tr:hover{background:rgba(41,182,246,0.08)}tbody td{padding:16px 20px;color:var(--text-dark);font-size:0.95rem}tbody td:first-child{font-weight:600;color:var(--text-mid);width:50px}tbody td:nth-child(2){font-weight:600;color:var(--text-dark);min-width:200px}tbody td:nth-child(3),tbody td:nth-child(4){text-align:center;font-weight:600;color:var(--accent)}.highlight-user{border:2px solid rgba(245,158,11,0.6);box-shadow:inset 0 0 0 1px rgba(245,158,11,0.4),0 0 20px rgba(245,158,11,0.2)}.highlight-user-row{background:rgba(41,182,246,0.15) !important;border-left:4px solid var(--accent);padding-left:16px}.highlight-user-row:hover{background:rgba(41,182,246,0.2) !important}@media (max-width:768px){.leaderboard-container{padding:24px 16px}.page-title{font-size:2rem;margin-bottom:8px}.page-subtitle{font-size:1rem;margin-bottom:24px}#timer{position:static;margin-bottom:20px}#weekly-quota-section{padding:24px 16px;margin-bottom:24px}.quota-display{flex-direction:column;align-items:flex-start}#top-three{flex-direction:column;align-items:center;gap:12px;min-height:auto}.top-contributor{flex:1;width:100%;max-width:300px;min-height:180px}.top-contributor:nth-child(1),.top-contributor:nth-child(2),.top-contributor:nth-child(3){order:initial;min-height:180px}table{font-size:0.85rem}thead th,tbody td{padding:12px 12px}.quota-input{flex-direction:column}.quota-input input{min-width:auto;width:100%}.quota-input button{width:100%;align-self:center}}@media (max-width:480px){.page-title{font-size:1.6rem}.tab-buttons{gap:8px}.tab-buttons button{padding:8px 16px;font-size:0.85rem}thead th{font-size:0.75rem;padding:10px 8px}tbody td{padding:10px 8px;font-size:0.85rem}.top-contributor .medal{font-size:2.5rem}.top-contributor .name{font-size:1rem}.top-contributor .points{font-size:1.4rem}}.text-center{text-align:center}.text-muted{color:var(--text-hint)}.text-accent{color:var(--accent)}.mt-small{margin-top:12px}.mt-medium{margin-top:24px}.mt-large{margin-top:32px}.mb-small{margin-bottom:12px}.mb-medium{margin-bottom:24px}.mb-large{margin-bottom:32px}
